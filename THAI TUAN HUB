-- ========== PHÁT HIỆN ROLE (CHÍNH XÁC) ==========
local function getPlayerRole(plr)
    if plr == LocalPlayer then return nil end
    
    -- 1. Kiểm tra leaderstats
    local ls = plr:FindFirstChild("leaderstats")
    if ls then
        local rs = ls:FindFirstChild("Role")
        if rs then
            local val = tostring(rs.Value)
            if val:find("Murderer") or val:find("Murder") then
                return "Murderer"
            elseif val:find("Sheriff") then
                return "Sheriff"
            end
        end
    end
    
    -- 2. Kiểm tra Backpack (kho đồ)
    if plr.Backpack then
        for _, tool in pairs(plr.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                if tool.Name == "Knife" then return "Murderer" end
                if tool.Name == "Gun" then return "Sheriff" end
            end
        end
    end
    
    -- 3. Kiểm tra Character (vũ khí đang cầm)
    if plr.Character then
        for _, tool in pairs(plr.Character:GetChildren()) do
            if tool:IsA("Tool") then
                if tool.Name == "Knife" then return "Murderer" end
                if tool.Name == "Gun" then return "Sheriff" end
            end
        end
        -- Kiểm tra CurrentTool
        local hum = plr.Character:FindFirstChild("Humanoid")
        if hum then
            local currentTool = hum:FindFirstChild("CurrentTool")
            if currentTool then
                if currentTool.Name == "Knife" then return "Murderer" end
                if currentTool.Name == "Gun" then return "Sheriff" end
            end
        end
    end
    
    return "Innocent"
end

-- ========== KIỂM TRA ROUND MỚI ==========
local function isNewRound()
    local hasWeapon = false
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if plr.Character then
                if plr.Character:FindFirstChild("Knife") or plr.Character:FindFirstChild("Gun") then
                    hasWeapon = true
                    break
                end
            end
            if plr.Backpack then
                if plr.Backpack:FindFirstChild("Knife") or plr.Backpack:FindFirstChild("Gun") then
                    hasWeapon = true
                    break
                end
            end
        end
    end
    return not hasWeapon
end

-- ========== ESP ==========
local function clearAllESP()
    for _, hl in pairs(espHighlights) do pcall(function() hl:Destroy() end) end
    espHighlights = {}
    for _, hl in pairs(gunHighlights) do pcall(function() hl:Destroy() end) end
    gunHighlights = {}
end

local function createPlayerESP(plr)
    if not espEnabled or not plr.Character then return end
    if espHighlights[plr] then
        pcall(function() espHighlights[plr]:Destroy() end)
    end
    
    local role = getPlayerRole(plr)
    local hl = Instance.new("Highlight")
    hl.Adornee = plr.Character
    hl.Parent = plr.Character
    hl.FillTransparency = 0.4
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    
    if role == "Murderer" then
        hl.FillColor = Color3.fromRGB(255, 0, 0)
    elseif role == "Sheriff" then
        hl.FillColor = Color3.fromRGB(0, 100, 255)
    else
        hl.FillColor = Color3.fromRGB(120, 120, 120)
    end
    espHighlights[plr] = hl
end

local function updateGunESP()
    for _, hl in pairs(gunHighlights) do pcall(function() hl:Destroy() end) end
    gunHighlights = {}
    if not espEnabled then return end
    
    for _, item in pairs(Workspace:GetDescendants()) do
        if item:IsA("Tool") and item.Name == "Gun" and item:FindFirstChild("Handle") then
            local parent = item.Parent
            if not parent:IsA("Model") or not parent:FindFirstChild("Humanoid") then
                local hl = Instance.new("Highlight")
                hl.Adornee = item
                hl.Parent = item
                hl.FillColor = Color3.fromRGB(255, 200, 0)
                hl.FillTransparency = 0.3
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                table.insert(gunHighlights, hl)
            end
        end
    end
end

local function refreshAllESP()
    if not espEnabled then return end
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            createPlayerESP(plr)
        end
    end
    updateGunESP()
end

-- ========== VÒNG LẶP ESP CHÍNH ==========
local lastRoundState = nil

local function startESPLoop()
    coroutine.wrap(function()
        while espEnabled do
            local roundState = isNewRound()
            
            -- Phát hiện round mới: reset toàn bộ
            if roundState ~= lastRoundState and roundState == true then
                lastRoundState = roundState
                clearAllESP()
                refreshAllESP()
            else
                lastRoundState = roundState
                -- Cập nhật màu cho từng người chơi
                for plr, hl in pairs(espHighlights) do
                    if hl and hl.Parent then
                        local role = getPlayerRole(plr)
                        if role == "Murderer" then
                            hl.FillColor = Color3.fromRGB(255, 0, 0)
                        elseif role == "Sheriff" then
                            hl.FillColor = Color3.fromRGB(0, 100, 255)
                        else
                            hl.FillColor = Color3.fromRGB(120, 120, 120)
                        end
                    end
                end
                updateGunESP()
            end
            task.wait(0.2)
        end
    end)()
end

local function toggleESP(state)
    espEnabled = state
    if state then
        lastRoundState = nil
        refreshAllESP()
        startESPLoop()
        
        -- Lắng nghe người chơi mới
        Players.PlayerAdded:Connect(function(plr)
            if espEnabled and plr ~= LocalPlayer then
                plr.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if espEnabled then createPlayerESP(plr) end
                end)
            end
        end)
        
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                plr.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if espEnabled then createPlayerESP(plr) end
                end)
            end
        end
        
        Rayfield:Notify({Title = "ESP", Content = "Đã bật! Tự động reset qua ván", Duration = 2})
    else
        clearAllESP()
        Rayfield:Notify({Title = "ESP", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== AIMBOT ==========
local function createAimCircle()
    if aimCircle then aimCircle:Destroy() end
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 110, 0, 110)
    circle.Position = UDim2.new(0.5, -55, 0.5, -55)
    circle.BackgroundTransparency = 1
    circle.BorderSizePixel = 4
    circle.BorderColor3 = Color3.fromRGB(255, 0, 0)
    circle.Visible = false
    circle.Parent = game:GetService("CoreGui")
    local circCorner = Instance.new("UICorner")
    circCorner.CornerRadius = UDim.new(1, 0)
    circCorner.Parent = circle
    return circle
end

local function startAimbot()
    if aimbotConn then aimbotConn:Disconnect() end
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then
            if aimCircle then aimCircle.Visible = false end
            return
        end
        if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then
            if not aimCircle then aimCircle = createAimCircle() end
            aimCircle.Visible = true
            local target = nil
            local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local bestDist = 450
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local role = getPlayerRole(plr)
                    if role == "Murderer" then
                        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local pos, on = Camera:WorldToScreenPoint(hrp.Position)
                            if on then
                                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                                if d < bestDist then
                                    bestDist = d
                                    target = hrp
                                end
                            end
                        end
                    end
                end
            end
            if target then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
            end
        else
            if aimCircle then aimCircle.Visible = false end
        end
    end)
end

local function toggleAimbot(state)
    aimbotEnabled = state
    if aimbotEnabled then
        startAimbot()
        Rayfield:Notify({Title = "Aimbot", Content = "Đã bật! Nhấn Shift Lock để kích hoạt", Duration = 2})
    else
        if aimbotConn then aimbotConn:Disconnect() end
        if aimCircle then aimCircle:Destroy() aimCircle = nil end
        Rayfield:Notify({Title = "Aimbot", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== GRAB GUN ==========
local function grabGun()
    if not LocalPlayer.Character then
        Rayfield:Notify({Title = "Lỗi", Content = "Không tìm thấy nhân vật!", Duration = 2})
        return
    end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local closestGun = nil
    local minDist = math.huge
    local pos = hrp.Position
    for _, item in pairs(Workspace:GetDescendants()) do
        if item:IsA("Tool") and item.Name == "Gun" and item:FindFirstChild("Handle") then
            local parent = item.Parent
            if not parent:IsA("Model") or not parent:FindFirstChild("Humanoid") then
                local d = (item.Handle.Position - pos).Magnitude
                if d < minDist then
                    minDist = d
                    closestGun = item
                end
            end
        end
    end
    if closestGun then
        hrp.CFrame = CFrame.new(closestGun.Handle.Position + Vector3.new(0, 2, 0))
        task.wait(0.15)
        local prompt = closestGun:FindFirstChild("ProximityPrompt")
        if prompt then
            prompt:InputHoldBegin()
            task.wait(0.1)
            prompt:InputHoldEnd()
        end
        Rayfield:Notify({Title = "Thành công", Content = "Đã nhặt được súng!", Duration = 2})
    else
        Rayfield:Notify({Title = "Lỗi", Content = "Không tìm thấy súng!", Duration = 2})
    end
end

-- ========== FLY ==========
local flyEnabled = false
local flyBV = nil
local function toggleFly(state)
    flyEnabled = state
    if state then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            flyBV = Instance.new("BodyVelocity")
            flyBV.MaxForce = Vector3.new(1/0, 1/0, 1/0)
            flyBV.Parent = hrp
        end
        RunService.Stepped:Connect(function()
            if flyEnabled and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root and flyBV then flyBV.Velocity = Vector3.new(0, 0, 0) end
            elseif flyBV then flyBV:Destroy() end
        end)
        Rayfield:Notify({Title = "Fly", Content = "Đã bật! Dùng WASD", Duration = 2})
    else
        if flyBV then flyBV:Destroy() end
        Rayfield:Notify({Title = "Fly", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== NOCLIP ==========
local noclipEnabled = false
local function toggleNoclip(state)
    noclipEnabled = state
    if state then
        RunService.Stepped:Connect(function()
            if noclipEnabled and LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
        Rayfield:Notify({Title = "NoClip", Content = "Đã bật xuyên tường!", Duration = 2})
    else
        Rayfield:Notify({Title = "NoClip", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== SPEED ==========
local speedEnabled = false
local originalSpeed = 16
local function toggleSpeed(state)
    speedEnabled = state
    if state and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            originalSpeed = hum.WalkSpeed
            hum.WalkSpeed = 60
        end
        Rayfield:Notify({Title = "Speed", Content = "Đã bật!", Duration = 2})
    elseif not state and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.WalkSpeed = originalSpeed end
        Rayfield:Notify({Title = "Speed", Content = "Đã tắt!", Duration = 2})
    end
end

