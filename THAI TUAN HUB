-- Cách 1: Phát hiện qua RemoteEvent (chính xác nhất)
local function setupRemoteDetection()
    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") and (remote.Name:lower():find("start") or remote.Name:lower():find("role") or remote.Name:lower():find("game") or remote.Name:lower():find("round")) then
            remote.OnClientEvent:Connect(function(data)
                if type(data) == "table" then
                    -- Kiểm tra nếu có Murderer hoặc Sheriff trong data
                    if data.Murderer or data.Sheriff or data.murderer or data.sheriff then
                        currentRound = currentRound + 1
                        roundDetected = true
                        if espEnabled then
                            resetESP()
                        end
                    end
                end
            end)
        end
    end
end
setupRemoteDetection()

-- Cách 2: Phát hiện qua sự kiện người chơi chết/respawn
local function setupPlayerDetection()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            plr.CharacterAdded:Connect(function(char)
                -- Kiểm tra nếu round mới bắt đầu (nhiều người respawn cùng lúc)
                task.wait(0.5)
                local hasWeapon = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        if p.Character:FindFirstChild("Knife") or p.Character:FindFirstChild("Gun") then
                            hasWeapon = true
                            break
                        end
                    end
                end
                if not hasWeapon and espEnabled then
                    resetESP()
                end
            end)
        end
    end
end
setupPlayerDetection()

-- ========== XÁC ĐỊNH ROLE ==========
local function getPlayerRole(plr)
    if plr == LocalPlayer then return "Local" end
    if not plr.Character then return "Innocent" end
    
    -- Kiểm tra CurrentTool (vũ khí đang cầm trên tay)
    local hum = plr.Character:FindFirstChild("Humanoid")
    if hum then
        local currentTool = hum:FindFirstChild("CurrentTool")
        if currentTool then
            if currentTool.Name == "Knife" then return "Murderer" end
            if currentTool.Name == "Gun" then return "Sheriff" end
        end
    end
    
    -- Kiểm tra vũ khí trên Character
    if plr.Character:FindFirstChild("Knife") then return "Murderer" end
    if plr.Character:FindFirstChild("Gun") then return "Sheriff" end
    
    -- Kiểm tra Backpack
    if plr.Backpack then
        if plr.Backpack:FindFirstChild("Knife") then return "Murderer" end
        if plr.Backpack:FindFirstChild("Gun") then return "Sheriff" end
    end
    
    -- Kiểm tra leaderstats (dự phòng)
    local ls = plr:FindFirstChild("leaderstats")
    if ls then
        local rs = ls:FindFirstChild("Role")
        if rs then
            local val = tostring(rs.Value)
            if val:find("Murderer") or val:find("Murder") then return "Murderer" end
            if val:find("Sheriff") then return "Sheriff" end
        end
    end
    
    return "Innocent"
end

-- ========== ESP ==========
local function createESP(plr)
    if not espEnabled or plr == LocalPlayer or not plr.Character then return end
    if espHighlights[plr] then
        pcall(function() espHighlights[plr]:Destroy() end)
        espHighlights[plr] = nil
    end
    
    local role = getPlayerRole(plr)
    playerRoleCache[plr.Name] = role
    
    local hl = Instance.new("Highlight")
    hl.Adornee = plr.Character
    hl.Parent = plr.Character
    hl.FillTransparency = 0.4
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    
    if role == "Murderer" then
        hl.FillColor = Color3.fromRGB(255, 0, 0)
    elseif role == "Sheriff" then
        hl.FillColor = Color3.fromRGB(0, 100, 255)
    else
        hl.FillColor = Color3.fromRGB(0, 200, 0)
    end
    espHighlights[plr] = hl
end

local function updateESPColor(plr)
    local hl = espHighlights[plr]
    if not hl or not hl.Parent then return end
    local role = getPlayerRole(plr)
    playerRoleCache[plr.Name] = role
    
    if role == "Murderer" then
        hl.FillColor = Color3.fromRGB(255, 0, 0)
    elseif role == "Sheriff" then
        hl.FillColor = Color3.fromRGB(0, 100, 255)
    else
        hl.FillColor = Color3.fromRGB(0, 200, 0)
    end
end

local function updateGunESP()
    for _, hl in pairs(gunHighlights) do pcall(function() hl:Destroy() end) end
    gunHighlights = {}
    if not espEnabled then return end
    
    for _, item in pairs(Workspace:GetDescendants()) do
        if item:IsA("Tool") and item.Name == "Gun" and item:FindFirstChild("Handle") then
            local parent = item.Parent
            if not parent:IsA("Model") or not parent:FindFirstChild("Humanoid") then
                local hl = Instance.new("Highlight")
                hl.Adornee = item
                hl.Parent = item
                hl.FillColor = Color3.fromRGB(255, 200, 0)
                hl.FillTransparency = 0.3
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                table.insert(gunHighlights, hl)
            end
        end
    end
end

-- ========== RESET ESP ==========
local function resetESP()
    if not espEnabled then return end
    
    -- Xóa hết highlight cũ
    for _, hl in pairs(espHighlights) do pcall(function() hl:Destroy() end) end
    espHighlights = {}
    for _, hl in pairs(gunHighlights) do pcall(function() hl:Destroy() end) end
    gunHighlights = {}
    playerRoleCache = {}
    
    -- Tạo lại ESP cho tất cả người chơi
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if plr.Character then
                createESP(plr)
            end
        end
    end
    updateGunESP()
    
    print("[THAI TU] ESP đã được reset!")
end

-- ========== VÒNG LẶP ESP CHÍNH ==========
local function startESPMonitor()
    coroutine.wrap(function()
        while espEnabled do
            -- Cập nhật role cho từng người chơi
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    local newRole = getPlayerRole(plr)
                    if playerRoleCache[plr.Name] ~= newRole then
                        playerRoleCache[plr.Name] = newRole
                        updateESPColor(plr)
                    end
                end
            end
            updateGunESP()
            task.wait(0.3)
        end
    end)()
end

-- ========== TOGGLE ESP ==========
local function toggleESP(state)
    espEnabled = state
    if state then
        resetESP()
        startESPMonitor()
        
        -- Lắng nghe người chơi mới
        local function onPlayerAdded(plr)
            if espEnabled then
                local conn = plr.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if espEnabled then
                        createESP(plr)
                    end
                end)
                table.insert(espConnections, conn)
            end
        end
        
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                local conn = plr.CharacterAdded:Connect(function()
                    task.wait(0.5)
                    if espEnabled then
                        createESP(plr)
                    end
                end)
                table.insert(espConnections, conn)
            end
        end
        
        local playerAddedConn = Players.PlayerAdded:Connect(onPlayerAdded)
        table.insert(espConnections, playerAddedConn)
        
        Rayfield:Notify({Title = "ESP", Content = "Đã bật! Tự động reset khi round mới", Duration = 2})
    else
        for _, conn in pairs(espConnections) do pcall(function() conn:Disconnect() end) end
        espConnections = {}
        for _, hl in pairs(espHighlights) do pcall(function() hl:Destroy() end) end
        espHighlights = {}
        for _, hl in pairs(gunHighlights) do pcall(function() hl:Destroy() end) end
        gunHighlights = {}
        playerRoleCache = {}
        Rayfield:Notify({Title = "ESP", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== AIMLOCK ==========
local function createFOVCircle()
    if aimCircle then aimCircle:Destroy() end
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 220, 0, 220)
    circle.Position = UDim2.new(0.5, -110, 0.5, -110)
    circle.BackgroundTransparency = 1
    circle.BorderSizePixel = 2
    circle.BorderColor3 = Color3.fromRGB(255, 255, 255)
    circle.Visible = false
    circle.Parent = game:GetService("CoreGui")
    local circCorner = Instance.new("UICorner")
    circCorner.CornerRadius = UDim.new(1, 0)
    circCorner.Parent = circle
    return circle
end

local function isPlayerHoldingGun()
    local char = LocalPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        local tool = hum:FindFirstChild("CurrentTool")
        if tool and (tool.Name == "Gun" or tool.Name:lower():find("gun")) then
            return true
        end
    end
    for _, child in pairs(char:GetChildren()) do
        if child:IsA("Tool") and (child.Name == "Gun" or child.Name:lower():find("gun")) then
            return true
        end
    end
    return false
end

local function startAimlock()
    if aimbotConnection then aimbotConnection:Disconnect() end
    
    aimCircle = createFOVCircle()
    local smoothness = 0.3
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then
            if aimCircle then aimCircle.Visible = false end
            return
        end
        
        local shiftLock = (UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter)
        if not shiftLock then
            if aimCircle then aimCircle.Visible = false end
            return
        end
        
        if not isPlayerHoldingGun() then
            if aimCircle then aimCircle.Visible = false end
            return
        end
        
        if aimCircle then aimCircle.Visible = true end
        
        local target = nil
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local bestDist = 220
        
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local role = playerRoleCache[plr.Name] or getPlayerRole(plr)
                if role == "Murderer" then
                    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local pos, onScreen = Camera:WorldToScreenPoint(hrp.Position)
                        if onScreen then
                            local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                            if d < bestDist then
                                bestDist = d
                                target = hrp
                            end
                        end
                    end
                end
            end
        end
        
        if target then
            local currentCF = Camera.CFrame
            local targetCF = CFrame.new(currentCF.Position, target.Position)
            local newCF = currentCF:Lerp(targetCF, smoothness)
            Camera.CFrame = newCF
        end
    end)
end

local function toggleAimlock(state)
    aimbotEnabled = state
    if state then
        startAimlock()
        Rayfield:Notify({Title = "Aimlock", Content = "Đã bật! Nhấn Shift Lock + cầm súng", Duration = 2})
    else
        if aimbotConnection then aimbotConnection:Disconnect() end
        if aimCircle then aimCircle:Destroy() aimCircle = nil end
        Rayfield:Notify({Title = "Aimlock", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== GRAB GUN ==========
local function teleportToGun(gun)
    if not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local originalPos = hrp.CFrame
    local gunPos = gun.Handle.CFrame * CFrame.new(0, 2, 0)
    
    hrp.CFrame = gunPos
    task.wait(0.15)
    
    local prompt = gun:FindFirstChild("ProximityPrompt")
    if prompt then
        prompt:InputHoldBegin()
        task.wait(0.1)
        prompt:InputHoldEnd()
    end
    
    hrp.CFrame = originalPos
end

local function startGrabGun()
    if grabGunConnection then return end
    
    grabGunConnection = Workspace.ChildAdded:Connect(function(child)
        if grabGunEnabled and child:IsA("Tool") and child.Name == "Gun" and child:FindFirstChild("Handle") then
            local parent = child.Parent
            if not parent:IsA("Model") or not parent:FindFirstChild("Humanoid") then
                safeCall(function()
                    teleportToGun(child)
                end)
            end
        end
    end)
    
    Rayfield:Notify({Title = "Grab Gun", Content = "Đã bật! Sẵn sàng nhặt súng", Duration = 2})
end

local function toggleGrabGun(state)
    grabGunEnabled = state
    if state then
        startGrabGun()
    else
        if grabGunConnection then
            grabGunConnection:Disconnect()
            grabGunConnection = nil
        end
        Rayfield:Notify({Title = "Grab Gun", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== FLY ==========
local function toggleFly(state)
    flyEnabled = state
    if state then
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            flyBV = Instance.new("BodyVelocity")
            flyBV.MaxForce = Vector3.new(1/0, 1/0, 1/0)
            flyBV.Parent = hrp
        end
        RunService.Stepped:Connect(function()
            if flyEnabled and LocalPlayer.Character then
                local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root and flyBV then flyBV.Velocity = Vector3.new(0, 0, 0) end
            elseif flyBV then flyBV:Destroy() end
        end)
        Rayfield:Notify({Title = "Fly", Content = "Đã bật! Dùng WASD", Duration = 2})
    else
        if flyBV then flyBV:Destroy() end
        Rayfield:Notify({Title = "Fly", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== NOCLIP ==========
local noclipEnabled = false
local function toggleNoclip(state)
    noclipEnabled = state
    if state then
        RunService.Stepped:Connect(function()
            if noclipEnabled and LocalPlayer.Character then
                for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
        Rayfield:Notify({Title = "NoClip", Content = "Đã bật!", Duration = 2})
    else
        Rayfield:Notify({Title = "NoClip", Content = "Đã tắt!", Duration = 2})
    end
end

-- ========== SPEED ==========
local speedEnabled = false
local function toggleSpeed(state)
    speedEnabled = state
    if state and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            originalSpeed = hum.WalkSpeed
            hum.WalkSpeed = 60
        end
        Rayfield:Notify({Title = "Speed", Content = "Đã bật!", Duration = 2})
    elseif not state and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.WalkSpeed = originalSpeed end
        Rayfield:Notify({Title = "Speed", Content = "Đã tắt!", Duration = 2})
    end
end

