-- ========== PHÁT HIỆN ROLE (ĐƠN GIẢN, CHÍNH XÁC) ==========
local function getPlayerRole(plr)
    if plr == LocalPlayer then return nil end
    
    -- Cách 1: Kiểm tra vũ khí đang cầm trên Character (nhanh nhất)
    if plr.Character then
        for _, child in pairs(plr.Character:GetChildren()) do
            if child:IsA("Tool") then
                if child.Name == "Knife" then return "Murderer" end
                if child.Name == "Gun" then return "Sheriff" end
            end
        end
        -- Kiểm tra CurrentTool
        local hum = plr.Character:FindFirstChild("Humanoid")
        if hum then
            local tool = hum:FindFirstChild("CurrentTool")
            if tool then
                if tool.Name == "Knife" then return "Murderer" end
                if tool.Name == "Gun" then return "Sheriff" end
            end
        end
    end
    
    -- Cách 2: Kiểm tra Backpack
    if plr.Backpack then
        for _, tool in pairs(plr.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                if tool.Name == "Knife" then return "Murderer" end
                if tool.Name == "Gun" then return "Sheriff" end
            end
        end
    end
    
    return "Innocent"
end

-- ========== ESP CHÍNH (LUÔN HOẠT ĐỘNG KHI BẬT) ==========
local espActive = false
local espLoopRunning = false

-- Xóa tất cả ESP
local function clearAllESP()
    for _, hl in pairs(espHighlights) do
        pcall(function() hl:Destroy() end)
    end
    espHighlights = {}
    for _, hl in pairs(gunHighlights) do
        pcall(function() hl:Destroy() end)
    end
    gunHighlights = {}
end

-- Tạo ESP cho một người chơi
local function createPlayerESP(plr)
    if not espEnabled or not plr.Character then return end
    if espHighlights[plr] then
        pcall(function() espHighlights[plr]:Destroy() end)
        espHighlights[plr] = nil
    end
    
    local role = getPlayerRole(plr)
    local hl = Instance.new("Highlight")
    hl.Adornee = plr.Character
    hl.Parent = plr.Character
    hl.FillTransparency = 0.4
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    
    if role == "Murderer" then
        hl.FillColor = Color3.fromRGB(255, 0, 0)
    elseif role == "Sheriff" then
        hl.FillColor = Color3.fromRGB(0, 100, 255)
    else
        hl.FillColor = Color3.fromRGB(120, 120, 120)
    end
    espHighlights[plr] = hl
end

-- Tạo ESP cho súng rớt
local function updateGunESP()
    for _, hl in pairs(gunHighlights) do
        pcall(function() hl:Destroy() end)
    end
    gunHighlights = {}
    if not espEnabled then return end
    
    for _, item in pairs(Workspace:GetDescendants()) do
        if item:IsA("Tool") and item.Name == "Gun" and item:FindFirstChild("Handle") then
            local parent = item.Parent
            if not parent:IsA("Model") or not parent:FindFirstChild("Humanoid") then
                local hl = Instance.new("Highlight")
                hl.Adornee = item
                hl.Parent = item
                hl.FillColor = Color3.fromRGB(255, 200, 0)
                hl.FillTransparency = 0.3
                hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                table.insert(gunHighlights, hl)
            end
        end
    end
end

-- Cập nhật toàn bộ ESP (gọi khi có thay đổi)
local function refreshAllESP()
    if not espEnabled then return end
    
    -- Cập nhật ESP cho từng người chơi
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if plr.Character then
                createPlayerESP(plr)
            end
        end
    end
    
    -- Cập nhật ESP súng
    updateGunESP()
end

-- Vòng lặp ESP chạy liên tục (cập nhật màu khi role thay đổi)
local function startESPLoop()
    if espLoopRunning then return end
    espLoopRunning = true
    
    coroutine.wrap(function()
        while espEnabled do
            -- Cập nhật màu cho từng người chơi
            for plr, hl in pairs(espHighlights) do
                if hl and hl.Parent then
                    local role = getPlayerRole(plr)
                    if role == "Murderer" then
                        if hl.FillColor ~= Color3.fromRGB(255, 0, 0) then
                            hl.FillColor = Color3.fromRGB(255, 0, 0)
                        end
                    elseif role == "Sheriff" then
                        if hl.FillColor ~= Color3.fromRGB(0, 100, 255) then
                            hl.FillColor = Color3.fromRGB(0, 100, 255)
                        end
                    else
                        if hl.FillColor ~= Color3.fromRGB(120, 120, 120) then
                            hl.FillColor = Color3.fromRGB(120, 120, 120)
                        end
                    end
                end
            end
            
            -- Cập nhật ESP súng
            updateGunESP()
            
            task.wait(0.3)
        end
        espLoopRunning = false
    end)()
end

-- Lắng nghe người chơi mới và nhân vật mới
local function setupESPListeners()
    -- Khi có người chơi mới vào game
    Players.PlayerAdded:Connect(function(plr)
        if espEnabled and plr ~= LocalPlayer then
            -- Khi nhân vật của họ xuất hiện
            plr.CharacterAdded:Connect(function(char)
                task.wait(0.5)
                if espEnabled and char then
                    createPlayerESP(plr)
                end
            end)
            if plr.Character then
                createPlayerESP(plr)
            end
        end
    end)
    
    -- Khi người chơi hiện tại respawn
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            plr.CharacterAdded:Connect(function(char)
                task.wait(0.5)
                if espEnabled and char then
                    createPlayerESP(plr)
                end
            end)
        end
    end
end

-- Bật/tắt ESP
local function toggleESP(state)
    espEnabled = state
    if state then
        clearAllESP()
        refreshAllESP()
        startESPLoop()
        setupESPListeners()
        Rayfield:Notify({Title = "ESP", Content = "Đã bật ESP!", Duration = 1})
    else
        clearAllESP()
        Rayfield:Notify({Title = "ESP", Content = "Đã tắt ESP!", Duration = 1})
    end
end

-- ========== AIMBOT ==========
local function createAimCircle()
    if aimCircle then aimCircle:Destroy() end
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 110, 0, 110)
    circle.Position = UDim2.new(0.5, -55, 0.5, -55)
    circle.BackgroundTransparency = 1
    circle.BorderSizePixel = 4
    circle.BorderColor3 = Color3.fromRGB(255, 0, 0)
    circle.Visible = false
    circle.Parent = game:GetService("CoreGui")
    local circCorner = Instance.new("UICorner")
    circCorner.CornerRadius = UDim.new(1, 0)
    circCorner.Parent = circle
    return circle
end

local function startAimbot()
    if aimbotConn then aimbotConn:Disconnect() end
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not aimbotEnabled then
            if aimCircle then aimCircle.Visible = false end
            return
        end
        
        if UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter then
            if not aimCircle then aimCircle = createAimCircle() end
            aimCircle.Visible = true
            
            local target = nil
            local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            local bestDist = 450
            
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local role = getPlayerRole(plr)
                    if role == "Murderer" then
                        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            local pos, onScreen = Camera:WorldToScreenPoint(hrp.Position)
                            if onScreen then
                                local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                                if d < bestDist then
                                    bestDist = d
                                    target = hrp
                                end
                            end
                        end
                    end
                end
            end
            
            if target then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
            end
        else
            if aimCircle then aimCircle.Visible = false end
        end
    end)
end

local function toggleAimbot(state)
    aimbotEnabled = state
    if aimbotEnabled then
        startAimbot()
        Rayfield:Notify({Title = "Aimbot", Content = "Đã bật! Nhấn Shift Lock để kích hoạt", Duration = 2})
    else
        if aimbotConn then aimbotConn:Disconnect() end
        if aimCircle then aimCircle:Destroy() aimCircle = nil end
        Rayfield:Notify({Title = "Aimbot", Content = "Đã tắt!", Duration = 1})
    end
end

-- ========== GRAB GUN ==========
local function grabGun()
    if not LocalPlayer.Character then
        Rayfield:Notify({Title = "Lỗi", Content = "Không tìm thấy nhân vật!", Duration = 2})
        return
    end
    
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local closestGun = nil
    local minDist = math.huge
    local charPos = hrp.Position
    
    for _, item in pairs(Workspace:GetDescendants()) do
        if item:IsA("Tool") and item.Name == "Gun" and item:FindFirstChild("Handle") then
            local parent = item.Parent
            if not parent:IsA("Model") or not parent:FindFirstChild("Humanoid") then
                local d = (item.Handle.Position - charPos).Magnitude
                if d < minDist then
                    minDist = d
                    closestGun = item
                end
            end
        end
    end
    
    if closestGun then
        hrp.CFrame = CFrame.new(closestGun.Handle.Position + Vector3.new(0, 2, 0))
        task.wait(0.15)
        
        local prompt = closestGun:FindFirstChild("ProximityPrompt")
        if prompt then
            prompt:InputHoldBegin()
            task.wait(0.1)
            prompt:InputHoldEnd()
        end
        
        Rayfield:Notify({Title = "Thành công", Content = "Đã nhặt được súng!", Duration = 2})
    else
        Rayfield:Notify({Title = "Lỗi", Content = "Không tìm thấy súng trên sàn!", Duration = 2})
    end
end

