local EspToggle = MainTab:AddToggle("EspToggle", {
    Title = "ESP",
    Description = "Bật/tắt ESP (phát hiện role qua leaderstats + vũ khí ngay đầu trận)",
    Default = false
})
EspToggle:OnChanged(function()
    espEnabled = EspToggle.Value
    if espEnabled then
        updateAllRoles()
        refreshESP()
        startESPLoop()
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                plr.CharacterAdded:Connect(function() 
                    task.wait(0.3)
                    if espEnabled then refreshESP() end
                end)
            end
        end
        Players.PlayerAdded:Connect(function(plr)
            if espEnabled then
                plr.CharacterAdded:Connect(function() 
                    task.wait(0.3)
                    if espEnabled then refreshESP() end
                end)
            end
        end)
        Fluent:Notify({Title = "ESP", Content = "ESP đã bật! Phát hiện role ngay đầu trận", Duration = 2})
    else
        for _, hl in pairs(espHighlights) do pcall(function() hl:Destroy() end) end
        espHighlights = {}
        for _, hl in pairs(gunHighlights) do pcall(function() hl:Destroy() end) end
        gunHighlights = {}
        Fluent:Notify({Title = "ESP", Content = "ESP đã tắt!", Duration = 1})
    end
end)

